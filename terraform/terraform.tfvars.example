# Copy to terraform.tfvars and fill in real values
# terraform.tfvars is gitignored — never commit it

hcloud_token         = "your-hetzner-api-token"
cloudflare_api_token = "your-cloudflare-api-token"

ssh_public_key = "ssh-ed25519 AAAA... jadlao@macbook"

server_name     = "prod-01"
server_type     = "cpx32"
server_location = "nbg1"
server_image    = "ubuntu-22.04"

server_ip = "178.104.132.83"

# Get zone IDs from Cloudflare dashboard or API:
#   curl -H "Authorization: Bearer TOKEN" \
#     "https://api.cloudflare.com/client/v4/zones" | jq '.result[] | {name, id}'
#
# Only include domains that are on Cloudflare.
# Other domains (on registrar DNS) are managed outside Terraform.

domains = {
  clinicaltrialsfinder = {
    domain  = "clinicaltrialsfinder.org"
    zone_id = "ZONE_ID_HERE"
  }
  govcontractscout = {
    domain  = "govcontractscout.com"
    zone_id = "ZONE_ID_HERE"
  }
  labpricecheck = {
    domain  = "labpricecheck.com"
    zone_id = "ZONE_ID_HERE"
  }
  govbidportals = {
    domain  = "govbidportals.com"
    zone_id = "ZONE_ID_HERE"
  }
  jxbit = {
    domain  = "jxbit.dev"
    zone_id = "ZONE_ID_HERE"
  }
  nousindex = {
    domain  = "nousindex.com"
    zone_id = "ZONE_ID_HERE"
  }
}
